!! Przykładowy program H#
!! Demonstracja składni H# + nowej sekcji skryptowej

# <bytes/std_io>

*{derive(Debug, Clone)}

Claas Osoba [
    imie: Str
    wiek: Int

    fn nowy(imie: Str, wiek: Int) -> Osoba [
        return new Osoba(imie: imie, wiek: wiek)
    ]

    fn przedstaw(self) -> Void [
        write "Cześć, jestem " + self.imie + ", lat: " + self.wiek as Str
    ]
]

fn main() -> Void [
    let o = new Osoba(imie: "Hacker", wiek: 25)
    o.przedstaw()

    let liczby: List[Int] = [1, 2, 3, 4, 5]
    let mut suma: Int = 0
    for n in liczby [
        suma = suma + n
    ]
    write "Suma: " + suma as Str

    match suma [
        15 => write "Wynik poprawny!",
        _  => write "Cos poszlo nie tak"
    ]

    !==
    Sekcja skryptowa - nowa mega prosta składnia
    Znacznie łatwiejsza niż reszta H# - brak OOP
    ==!

    ---
    ! Sprawdź zależności systemowe
    dep curl git

    ! Zmienne skryptowe
    $projekt = "H#"
    $wersja = "0.1.0"

    ! Wyświetlanie - ;;
    ;; "Buduję projekt:" $projekt
    ;; "Wersja:" $wersja

    ! Zwykła komenda >
    > echo "Hello z sekcji skryptowej!"

    ! Komenda ze zmiennymi skryptowymi >>
    >> echo "Projekt: $PROJEKT wersja: $WERSJA"

    ! Izolowane środowisko >>>
    >>> echo "Izolowane wykonanie"

    ! Pipe >
    > ls /tmp | grep "tmp" | head -5

    ! Warunek ? ... ] ?? ...
    ? $wersja == "0.1.0" [
        ;; "Wersja development"
    ]
    ?? [
        ;; "Wersja produkcyjna"
    ]

    ! Pętla @ $var w range
    @ $i w 1..4 [
        ;; "Iteracja:" $i
    ]

    ! Pętla po wyjściu komendy
    @ $plik w > ls /tmp [
        ;; "Znaleziono:" $plik
    ]

    ! Funkcja skryptowa
    ;fn powitaj $imie [
        ;; "Cześć," $imie "!"
    ]
    ;call powitaj "HackerOS"

    ! Zakończenie
    ;; "Skrypt zakończony pomyślnie"
    ---
]
