/// Minimum of two integers.
pub fn min(a: int, b: int) -> int is
    if a < b is return a end
    return b
end

/// Maximum of two integers.
pub fn max(a: int, b: int) -> int is
    if a > b is return a end
    return b
end

/// Minimum of two floats.
pub fn fmin(a: f64, b: f64) -> f64 is
    if a < b is return a end
    return b
end

/// Maximum of two floats.
pub fn fmax(a: f64, b: f64) -> f64 is
    if a > b is return a end
    return b
end

/// Clamp an integer to [lo, hi].
pub fn clamp(v: int, lo: int, hi: int) -> int is
    if v < lo is return lo end
    if v > hi is return hi end
    return v
end

/// Clamp a float to [lo, hi].
pub fn fclamp(v: f64, lo: f64, hi: f64) -> f64 is
    if v < lo is return lo end
    if v > hi is return hi end
    return v
end

/// Greatest common divisor.
pub fn gcd(a: int, b: int) -> int is
    let mut x: int = abs(a)
    let mut y: int = abs(b)
    while y != 0 is
        let t: int = y
        y = x % y
        x = t
    end
    return x
end

/// Least common multiple.
pub fn lcm(a: int, b: int) -> int is
    if a == 0 || b == 0 is return 0 end
    return abs(a / gcd(a, b) * b)
end

pub let PI:  f64 = 3.141592653589793
pub let E:   f64 = 2.718281828459045
pub let TAU: f64 = 6.283185307179586

pub fn pi()  -> f64 = PI
pub fn e()   -> f64 = E
pub fn tau() -> f64 = TAU
