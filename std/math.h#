;; std -> math — Mathematical functions
;; H# Standard Library v0.8

pub fn sin(x: f64) -> f64 is
    return __builtin_math_sin(x)
end

pub fn cos(x: f64) -> f64 is
    return __builtin_math_cos(x)
end

pub fn tan(x: f64) -> f64 is
    return __builtin_math_tan(x)
end

pub fn asin(x: f64) -> f64 is
    return __builtin_math_asin(x)
end

pub fn acos(x: f64) -> f64 is
    return __builtin_math_acos(x)
end

pub fn atan(x: f64) -> f64 is
    return __builtin_math_atan(x)
end

pub fn atan2(y: f64, x: f64) -> f64 is
    return __builtin_math_atan2(y, x)
end

/// Square root of a float.
pub fn sqrt(x: f64) -> f64 is
    return __builtin_math_sqrt(x)
end

/// Absolute value of an integer.
pub fn abs(x: int) -> int is
    if x < 0 is return -x end
    return x
end

/// Absolute value of a float.
pub fn fabs(x: f64) -> f64 is
    if x < 0.0 is return -x end
    return x
end

pub fn pow(base: f64, exp: f64) -> f64 is
    return __builtin_math_pow(base, exp)
end

/// Integer power (repeated multiplication).
pub fn ipow(base: int, exp: int) -> int is
    let mut result: int = 1
    let mut i: int = 0
    while i < exp is
        result = result * base
        i += 1
    end
    return result
end

