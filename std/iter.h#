/// Map over an array, applying f to each element.
pub fn map(arr: [any], f: fn(any) -> any) -> [any] is
    let mut result: [any] = []
    for x in arr is
        result.push(f(x))
    end
    return result
end

/// Filter an array, keeping elements where f returns true.
pub fn filter(arr: [any], f: fn(any) -> bool) -> [any] is
    let mut result: [any] = []
    for x in arr is
        if f(x) is
            result.push(x)
        end
    end
    return result
end

/// Reduce (fold) an array to a single value.
pub fn reduce(arr: [any], init: any, f: fn(any, any) -> any) -> any is
    let mut acc = init
    for x in arr is
        acc = f(acc, x)
    end
    return acc
end

/// Zip two arrays into an array of tuples.
pub fn zip(a: [any], b: [any]) -> [(any, any)] is
    let mut result: [(any, any)] = []
    let len = if a.len() < b.len() is a.len() else is b.len() end
    let mut i: int = 0
    while i < len is
        result.push((a[i], b[i]))
        i += 1
    end
    return result
end

/// Chain two arrays into one.
pub fn chain(a: [any], b: [any]) -> [any] is
    let mut result: [any] = []
    for x in a is result.push(x) end
    for x in b is result.push(x) end
    return result
end

/// Take first n elements.
pub fn take(arr: [any], n: int) -> [any] is
    let limit = if n < arr.len() is n else is arr.len() end
    let mut result: [any] = []
    let mut i: int = 0
    while i < limit is
        result.push(arr[i])
        i += 1
    end
    return result
end

/// Skip first n elements.
pub fn skip(arr: [any], n: int) -> [any] is
    if n >= arr.len() is return [] end
    return arr[n..]
end

/// Take elements while predicate is true.
pub fn take_while(arr: [any], f: fn(any) -> bool) -> [any] is
    let mut result: [any] = []
    for x in arr is
        if !f(x) is break end
        result.push(x)
    end
    return result
end

/// Drop elements while predicate is true.
pub fn drop_while(arr: [any], f: fn(any) -> bool) -> [any] is
    let mut dropping: bool = true
    let mut result: [any] = []
    for x in arr is
        if dropping && f(x) is continue end
        dropping = false
        result.push(x)
    end
    return result
end

/// Check if any element satisfies predicate.
pub fn any(arr: [any], f: fn(any) -> bool) -> bool is
    for x in arr is
        if f(x) is return true end
    end
    return false
end

/// Check if all elements satisfy predicate.
pub fn all(arr: [any], f: fn(any) -> bool) -> bool is
    for x in arr is
        if !f(x) is return false end
    end
    return true
end

/// Count elements satisfying predicate.
pub fn count(arr: [any], f: fn(any) -> bool) -> int is
    let mut n: int = 0
    for x in arr is
        if f(x) is n += 1 end
    end
    return n
end

/// Find first element satisfying predicate.
pub fn find(arr: [any], f: fn(any) -> bool) -> any is
    for x in arr is
        if f(x) is return x end
    end
    return nil
end

/// Flatten an array of arrays into a single array.
pub fn flatten(arr: [[any]]) -> [any] is
    let mut result: [any] = []
    for sub in arr is
        for x in sub is result.push(x) end
    end
    return result
end

/// FlatMap: map + flatten.
pub fn flat_map(arr: [any], f: fn(any) -> [any]) -> [any] is
    let mut result: [any] = []
    for x in arr is
        for y in f(x) is result.push(y) end
    end
    return result
end

/// Create array of n repetitions of val.
pub fn repeat(val: any, n: int) -> [any] is
    let mut result: [any] = []
    let mut i: int = 0
    while i < n is
        result.push(val)
        i += 1
    end
    return result
end

/// Enumerate: returns [(index, value), ...].
pub fn enumerate(arr: [any]) -> [(int, any)] is
    let mut result: [(int, any)] = []
    let mut i: int = 0
    for x in arr is
        result.push((i, x))
        i += 1
    end
    return result
end

/// Partition array into (matching, not-matching) tuple.
pub fn partition(arr: [any], f: fn(any) -> bool) -> ([any], [any]) is
    let mut yes: [any] = []
    let mut no:  [any] = []
    for x in arr is
        if f(x) is yes.push(x) else is no.push(x) end
    end
    return (yes, no)
end

/// Sum integer array.
pub fn sum(arr: [int]) -> int is
    let mut s: int = 0
    for x in arr is s += x end
    return s
end

/// Product of integer array.
pub fn product(arr: [int]) -> int is
    let mut p: int = 1
    for x in arr is p *= x end
    return p
end

/// Unique: remove duplicates, preserve order.
pub fn unique(arr: [any]) -> [any] is
    let mut seen: [any] = []
    let mut result: [any] = []
    for x in arr is
        let mut found: bool = false
        for s in seen is
            if s == x is found = true; break end
        end
        if !found is
            seen.push(x)
            result.push(x)
        end
    end
    return result
end

/// Reverse an array.
pub fn reverse(arr: [any]) -> [any] is
    let mut result: [any] = []
    let mut i: int = arr.len() - 1
    while i >= 0 is
        result.push(arr[i])
        i -= 1
    end
    return result
end
