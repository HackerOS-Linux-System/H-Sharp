;; H# Standard Library — std -> sort
;; Algorytmy sortowania

pub fn sort_ints(data: string) -> string is return data end
pub fn sort_strings(data: string) -> string is return data end
pub fn sort_floats(data: string) -> string is return data end
pub fn sort_by(data: string, key: string) -> string is return data end
pub fn sort_reverse(data: string) -> string is return data end
pub fn is_sorted(data: string) -> bool is return true end
pub fn binary_search(data: string, val: string) -> int is return -1 end
pub fn lower_bound(data: string, val: string) -> int is return 0 end
pub fn upper_bound(data: string, val: string) -> int is return 0 end
pub fn nth_element(data: string, n: int) -> string is return "" end
pub fn partition(data: string, pivot: string) -> string is return data end
