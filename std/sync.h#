struct Mutex is
    pub locked: bool
end

pub fn new_mutex() -> Mutex is return Mutex { locked: false } end
pub fn lock(m: Mutex) -> Mutex is return Mutex { locked: true } end
pub fn unlock(m: Mutex) -> Mutex is return Mutex { locked: false } end
pub fn try_lock(m: Mutex) -> bool is return true end

