use "std -> crypto -> hex" from "hex"
use "std -> sec"           from "sec"
use "std -> encoding -> base64" from "b64"

fn xor_bytes(data: string, key: string) -> string is
    ;; sec::xor(data_bytes, key_bytes) — real impl
    return "xored:" + data
end

fn print_hex(label: string, data: string) is
    write(label + ": " + data)
end

fn to_base64(data: string) -> string is
    ;; b64::encode(data)
    return "base64:" + data
end

fn main() is
    write("H# XOR Cipher Tool")
    write("══════════════════")
    write("")

    let plaintext: string = "48656C6C6F"  ;; "Hello" in hex
    let key:       string = "AABBCCDDEE"

    print_hex("Plaintext ", plaintext)
    print_hex("Key       ", key)

    let ciphertext: string = xor_bytes(plaintext, key)
    print_hex("Ciphertext", ciphertext)

    let decoded: string = xor_bytes(ciphertext, key)
    print_hex("Decrypted ", decoded)

    write("")
    write("Base64 encoded: " + to_base64(plaintext))
    write("")
    write("Done.")
end
