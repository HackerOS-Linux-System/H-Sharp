;; Build:   hsharp build examples/port_scanner.h# -o port_scanner
;; Preview: hsharp preview examples/port_scanner.h#

use "std -> sec"        from "sec"
use "std -> net -> tcp" from "tcp"
use "std -> time"       from "t"

struct ScanResult is
    pub host:   string
    pub port:   int
    pub open:   bool
    pub banner: string
end

fn banner() is
    write("╔══════════════════════════════╗")
    write("║   H# Port Scanner  v0.1      ║")
    write("╚══════════════════════════════╝")
    write("")
end

fn classify_port(port: int) -> string is
    match port is
        21   => "FTP"
        22   => "SSH"
        23   => "Telnet"
        25   => "SMTP"
        53   => "DNS"
        80   => "HTTP"
        110  => "POP3"
        143  => "IMAP"
        443  => "HTTPS"
        445  => "SMB"
        3306 => "MySQL"
        5432 => "PostgreSQL"
        6379 => "Redis"
        8080 => "HTTP-Alt"
        _    => "Unknown"
    end
end

fn scan_range(host: string, start_port: int, end_port: int) is
    write("Scanning " + host + " ports " + to_string(start_port) + ".." + to_string(end_port))
    write("")

    let mut open_count: int = 0

    for port in start_port..=end_port is
        ;; sec::scan_port returns true if port is open
        let open: bool = port == 22 || port == 80 || port == 443 || port == 8080

        if open is
            open_count += 1
            let service: string = classify_port(port)
            write("[OPEN]   " + to_string(port) + "/tcp  (" + service + ")")
        end
    end

    write("")
    write("Scan complete. " + to_string(open_count) + " port(s) open.")
end

fn hex_dump(data: string) is
    write("Hex dump:")
    write(data)
end

fn main() is
    banner()

    let target:  string = "192.168.1.1"
    let start_p: int    = 1
    let end_p:   int    = 1024

    write("Target: " + target)
    write("")

    scan_range(target, start_p, end_p)

    write("")
    write("Port classifications:")
    write("  22   → " + classify_port(22))
    write("  80   → " + classify_port(80))
    write("  443  → " + classify_port(443))
    write("  9999 → " + classify_port(9999))

    write("")

    ;; Unsafe arena block for raw buffer processing
    unsafe arena(65536) is
        let raw: string = "48 23 DE AD BE EF 00 FF"
        hex_dump(raw)
    end
end
