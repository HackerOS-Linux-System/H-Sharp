;; H# Closures Tests
use "std -> test" from "test"

#[test]
fn test_closure_basic() is
    let double = |x: int| -> int is x * 2 end
    assert_eq(double(5), 10)
    assert_eq(double(0), 0)
    assert_eq(double(-3), -6)
end

#[test]
fn test_closure_capture_immutable() is
    let factor: int = 7
    let mul = |x: int| -> int is x * factor end
    assert_eq(mul(3), 21)
    assert_eq(mul(0), 0)
end

;; NOTE: mutable capture-by-reference (a closure mutating a variable from
;; its enclosing scope, with that mutation visible after the closure
;; returns) is NOT yet supported. Env::flatten_for_capture() captures
;; variables by value (clone), and invoke_fn_value() discards the closure's
;; mutated environment when it returns rather than writing it back into the
;; Value::Fn that holds it. Supporting true mutable capture would require
;; Env to use shared interior mutability (e.g. Rc<RefCell<...>> per
;; variable) instead of value-cloned scopes — an architectural change
;; tracked for a future version rather than attempted here. Closures DO
;; correctly capture by value (read-only access to outer variables), as
;; covered by test_closure_capture_immutable above.

#[test]
fn test_closure_as_argument() is
    fn apply(x: int, f: fn(int) -> int) -> int is
        return f(x)
    end
    let square = |x: int| -> int is x * x end
    assert_eq(apply(4, square), 16)
    assert_eq(apply(5, square), 25)
end

#[test]
fn test_closure_returned() is
    fn make_adder(n: int) -> fn(int) -> int is
        return |x: int| -> int is x + n end
    end
    let add10 = make_adder(10)
    let add5  = make_adder(5)
    assert_eq(add10(3), 13)
    assert_eq(add5(3), 8)
end

#[test]
fn test_closure_multiline() is
    let process = |x: int, y: int| -> int is
        let sum  = x + y
        let prod = x * y
        return sum + prod
    end
    assert_eq(process(2, 3), 11)  ;; (2+3) + (2*3) = 5 + 6 = 11
end

#[test]
fn test_closure_in_loop() is
    let mut results: [int] = []
    for i in 1..=5 is
        let sq = |n: int| -> int is n * n end
        results.push(sq(i))
    end
    assert_eq(results[0], 1)
    assert_eq(results[1], 4)
    assert_eq(results[4], 25)
end
