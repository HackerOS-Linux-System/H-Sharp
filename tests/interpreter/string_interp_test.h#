;; H# String Interpolation Tests (v0.6)
use "std -> test" from "test"

#[test]
fn test_basic_interp() is
    let name = "World"
    let msg  = "Hello, {name}!"
    assert_eq(msg, "Hello, World!")
end

#[test]
fn test_interp_int() is
    let x   = 42
    let msg = "Value: {x}"
    assert_eq(msg, "Value: 42")
end

#[test]
fn test_interp_expression() is
    let a = 10
    let b = 5
    let msg = "Sum: {a + b}, Product: {a * b}"
    assert_eq(msg, "Sum: 15, Product: 50")
end

#[test]
fn test_interp_nested() is
    let first = "H"
    let last  = "#"
    let lang  = "{first}{last}"
    assert_eq(lang, "H#")
end

#[test]
fn test_interp_method_call() is
    let arr = [1, 2, 3]
    let msg = "Length: {arr.len()}"
    assert_eq(msg, "Length: 3")
end

#[test]
fn test_interp_float() is
    let pi   = 3.14
    let msg  = "Pi is {pi}"
    assert_true(msg.starts_with("Pi is 3"))
end

#[test]
fn test_interp_bool() is
    let flag = true
    let msg  = "Flag: {flag}"
    assert_eq(msg, "Flag: true")
end

#[test]
fn test_interp_escaped_brace() is
    let msg = "literal {{braces}}"
    assert_eq(msg, "literal {{braces}}")
end

#[test]
fn test_interp_multivar() is
    let a = 1
    let b = 2
    let c = 3
    let msg = "{a}+{b}+{c}={a + b + c}"
    assert_eq(msg, "1+2+3=6")
end
