;; H# Core Arithmetic Tests
use "std -> test" from "test"
use "std -> math" from "math"

#[test]
fn test_int_add() is
    assert_eq(1 + 1, 2)
    assert_eq(-5 + 5, 0)
    assert_eq(100 + 200, 300)
end

#[test]
fn test_int_sub() is
    assert_eq(10 - 3, 7)
    assert_eq(0 - 5, -5)
    assert_eq(-3 - (-3), 0)
end

#[test]
fn test_int_mul() is
    assert_eq(3 * 4, 12)
    assert_eq(-2 * 5, -10)
    assert_eq(0 * 999, 0)
end

#[test]
fn test_int_div() is
    assert_eq(10 / 2, 5)
    assert_eq(7 / 2, 3)
    assert_eq(-9 / 3, -3)
end

#[test]
fn test_int_mod() is
    assert_eq(10 % 3, 1)
    assert_eq(7 % 7, 0)
    assert_eq(1 % 5, 1)
end

#[test]
fn test_float_ops() is
    let a: f64 = 3.14
    let b: f64 = 2.0
    assert_true(a + b > 5.0)
    assert_true(a * b > 6.0)
end

#[test]
fn test_operator_precedence() is
    assert_eq(2 + 3 * 4, 14)
    assert_eq((2 + 3) * 4, 20)
    assert_eq(10 - 2 * 3, 4)
end

#[test]
fn test_bitwise() is
    assert_eq(0b1010 & 0b1100, 0b1000)
    assert_eq(0b1010 | 0b0101, 0b1111)
    assert_eq(0b1111 ^ 0b0101, 0b1010)
    assert_eq(1 << 3, 8)
    assert_eq(16 >> 2, 4)
end

#[test]
fn test_math_sqrt() is
    assert_eq(math::sqrt(9.0) as int, 3)
    assert_eq(math::sqrt(16.0) as int, 4)
end

#[test]
fn test_math_abs() is
    assert_eq(math::abs(-5), 5)
    assert_eq(math::abs(5), 5)
    assert_eq(math::abs(0), 0)
end

#[test]
fn test_math_min_max() is
    assert_eq(math::min(3, 7), 3)
    assert_eq(math::max(3, 7), 7)
    assert_eq(math::min(-1, 1), -1)
end

#[test]
fn test_overflow_check() is
    let big: i64 = 9223372036854775807
    assert_true(big > 0)
end
